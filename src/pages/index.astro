---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
title="High-Precision PCB Manufacturing & Assembly in China | XingFeng PCB"
description="Your Trusted PCB Board Manufacturer from Prototype to Mass Production. We deliver quality, speed, and cost-effective solutions for global innovators."
keywords="pcb manufacturing, pcb board manufacturer, pcba manufacturing, pcb printed circuit board manufacturing, pcb board production, pcb manufacturing software, pcb circuit board manufacturers, pcb board maker"
  cssExtra={['/css/about.css', '/css/index.css']}
>
  <main>
<!-- 第一屏：Hero Section (视觉冲击与核心价值主张) -->
        <section class="home-hero">
            <div class="container hero-grid">
                <div class="hero-text">
                    <h1>High-Precision <br><span>PCB Manufacturing</span> <br>& Assembly in China</h1>
                    <h2>Your Trusted PCB Board Manufacturer from Prototype to Mass Production. We deliver uncompromising quality, speed, and cost-effective solutions for global innovators.</h2>
                    <ul class="hero-benefits" style="list-style: none; padding: 0; margin: 20px 0; color: #fff;">
                        <li style="margin-bottom: 10px;">✓ ISO 9001 & UL Certified Facility</li>
                        <li style="margin-bottom: 10px;">✓ IPC-A-600 Class 2 & 3 Standards</li>
                        <li style="margin-bottom: 10px;">✓ 24-Hour Rapid Prototyping Available</li>
                    </ul>
                </div>
                <!-- Hero Form -->
                <div class="hero-form-wrapper" id="quote">
                    <form class="quick-quote-form" action="https://api.web3forms.com/submit" method="POST">
                        <h3>Get a Free Quote within 24 Hours</h3>
                        <!-- 核心配置 --> 
                        <input type="hidden" name="access_key" value="40f0bc17-2a5a-45e0-85cf-99aa9d8b06df"> 
                        <input type="hidden" name="honeypot" style="display:none;"> 
                        <input type="hidden" name="page_url" value="https://xfpcb.com/"> 
                        <input type="hidden" name="subject" value="Product Inquiry from Homepage Hero Form"> 
                        <input type="hidden" name="redirect" value="https://xfpcb.com/"> 
                        
                        <input type="text" name="name" placeholder="Your Name / Company" required style="margin-bottom: 15px;">
                        <input type="email" name="email" placeholder="Work Email Address" required style="margin-bottom: 15px;">
                        <select name="service_type" required style="width: 100%; padding: 12px; border-radius: 4px; border: none; margin-bottom: 15px; background: rgba(255,255,255,0.9);">
                            <option value="" disabled selected>Select Service Type</option>
                            <option value="pcb_fabrication">PCB Fabrication Only</option>
                            <option value="pcb_assembly">Turnkey PCBA (Fabrication + Assembly)</option>
                            <option value="rapid_prototyping">Rapid Prototyping</option>
                        </select>
                        <textarea name="message" placeholder="Project Details (Layer count, Quantity...)" rows="3" style="margin-bottom: 15px;" required></textarea>
                        
                        <button type="submit" class="cta-btn" style="width: 100%;">Get a Free Quote within 24 Hours</button>
                        <p class="form-note" style="color: #ccc; font-size: 0.85rem; text-align: center; margin-top: 10px;">🔒 Your design files are protected under strict NDA.</p>
                    </form>
                </div>
            </div>
        </section>

        <!-- 新增：Featured Products Section (展示 8 个代表性产品) -->
        <section class="home-products">
            <div class="container">
                <h2 class="section-title center">Comprehensive PCB Manufacturing Capabilities</h2>
                <p class="text-content center" style="max-width: 800px; margin: 0 auto;">From ultra-low cost single-sided boards for consumer electronics to 40-layer advanced backplanes for quantum computing, XingFeng PCB offers a complete spectrum of fabrication solutions.</p>
                
                <div class="home-products-grid">
                    <a href="/products/1-layer-pcb/" class="home-product-card">
                        <h3>1-Layer PCB</h3>
                        <p>Ultra-low cost, high volume single-sided boards for LED lighting & consumer electronics.</p>
                        <span class="card-link">Explore Capabilities →</span>
                    </a>
                    
                    <a href="/products/2-layer-pcb/" class="home-product-card">
                        <h3>2-Layer PCB</h3>
                        <p>Fast & reliable double-sided PTH boards. Perfect for rapid prototyping and makers.</p>
                        <span class="card-link">Explore Capabilities →</span>
                    </a>
                    
                    <a href="/products/4-layer-pcb/" class="home-product-card">
                        <h3>4-Layer PCB</h3>
                        <p>The sweet spot for IoT & Smart Home devices. Superior EMI shielding with dedicated GND/VCC.</p>
                        <span class="card-link">Explore Capabilities →</span>
                    </a>
                    
                    <a href="/products/6-layer-pcb/" class="home-product-card">
                        <h3>6-Layer PCB</h3>
                        <p>Engineered for industrial control & automotive. Strict impedance control and high reliability.</p>
                        <span class="card-link">Explore Capabilities →</span>
                    </a>
                    
                    <a href="/products/8-layer-pcb/" class="home-product-card">
                        <h3>8-Layer PCB</h3>
                        <p>Mastering High-Speed Signal Integrity. Blind/buried vias (HDI) for telecom & advanced motherboards.</p>
                        <span class="card-link">Explore Capabilities →</span>
                    </a>
                    
                    <a href="/products/12-layer-pcb/" class="home-product-card">
                        <h3>12-Layer PCB</h3>
                        <p>Cutting-edge tech for 5G & Data Centers. Hybrid stackups, advanced microvias, and backdrilling.</p>
                        <span class="card-link">Explore Capabilities →</span>
                    </a>
                    
                    <a href="/products/16-layer-pcb/" class="home-product-card">
                        <h3>16-Layer PCB</h3>
                        <p>Mastering Any-Layer HDI. Dedicated 1-on-1 CAM support for semiconductor test equipment.</p>
                        <span class="card-link">Explore Capabilities →</span>
                    </a>
                    
                    <a href="/products/40-layer-pcb/" class="home-product-card">
                        <h3>40-Layer PCB</h3>
                        <p>Pushing the limits of physics. Engineered for quantum computing interfaces & core network routers.</p>
                        <span class="card-link">Explore Capabilities →</span>
                    </a>
                </div>
                
                <div style="text-align: center; margin-top: 40px;">
                    <a href="/products/multilayer-pcb/" class="cta-button">Read Our Ultimate Multilayer Guide</a>
                </div>
            </div>
        </section>

        <!-- 第二屏：Our Core Services (核心业务板块) -->
        <section class="container">
            <h2 class="section-title center">Comprehensive PCB Printed Circuit Board Manufacturing Services</h2>
            <div class="services-grid">
                <!-- Card 1: Fabrication -->
                <div class="service-card">
                    <svg class="service-icon" viewBox="0 0 24 24">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="8" y1="3" x2="8" y2="7"></line>
                        <line x1="16" y1="3" x2="16" y2="7"></line>
                        <line x1="3" y1="12" x2="7" y2="12"></line>
                        <line x1="17" y1="12" x2="21" y2="12"></line>
                        <circle cx="12" cy="12" r="2"></circle>
                    </svg>
                    <h3>Custom PCB Fabrication</h3>
                    <p class="text-content">Advanced PCB board production for Rigid, Flex, HDI, and Metal Core boards. High reliability for demanding applications.</p>
                </div>

                <!-- Card 2: PCBA -->
                <div class="service-card">
                    <svg class="service-icon" viewBox="0 0 24 24">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    <h3>Turnkey PCBA Manufacturing</h3>
                    <p class="text-content">From component sourcing to full SMT/THT assembly. Our PCBA manufacturing lines are equipped with the latest Yamaha and AOI machines.</p>
                </div>

                <!-- Card 3: Prototyping -->
                <div class="service-card">
                    <svg class="service-icon" viewBox="0 0 24 24">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                    </svg>
                    <h3>Rapid Prototyping</h3>
                    <p class="text-content">Accelerate your R&D with our 24-hour quick-turn services. Test your designs faster and bring products to market ahead of the competition.</p>
                </div>
            </div>
        </section>

        <!-- 第三屏：Engineering & DFM (巧妙融入 Software 关键词) -->
        <section class="bg-darker">
            <div class="container">
                <h2 class="section-title center">Seamless Integration with Leading PCB Manufacturing Software</h2>
                <p class="text-content center" style="max-width: 900px; margin: 0 auto; text-align: center;">
                    We support all major CAD formats and <strong>PCB manufacturing software</strong>. Every order includes a comprehensive, free Design for Manufacturing (DFM) review by our expert engineers to ensure your Gerber files are perfectly optimized for production, reducing costs and preventing delays.
                </p>
                <div class="software-logos">
                    <div class="logo-box">Altium Designer</div>
                    <div class="logo-box">Autodesk EAGLE</div>
                    <div class="logo-box">KiCad EDA</div>
                    <div class="logo-box">Cadence Allegro</div>
                    <div class="logo-box">PADS</div>
                </div>
            </div>
        </section>

        <!-- 第四屏：Why Choose XingFeng PCB (建立工厂优势) -->
        <section class="container">
            <div class="choose-grid">
                <div class="choose-visual">
                    <div class="stat-circle">
                        <span class="pct">99.8%</span>
                        <span class="lbl">On-time Delivery</span>
                    </div>
                    <div class="stat-circle">
                        <span class="pct">40+</span>
                        <span class="lbl">Layers Capability</span>
                    </div>
                    <div class="stat-circle" style="margin-top: -30px;">
                        <span class="pct">24/7</span>
                        <span class="lbl">Global Support</span>
                    </div>
                </div>
                <div class="choose-text">
                    <h2 class="section-title">Why Partner With Us as Your PCB Board Maker?</h2>
                    <p class="text-content">As a direct <strong>PCB circuit board manufacturer</strong> based in Shenzhen, China's tech hub, we eliminate the middleman, offering you unparalleled advantages.</p>
                    <ul class="benefit-list">
                        <li>
                            <strong>Direct Factory Pricing</strong>
                            Cut costs without compromising IPC Class 2/3 quality. Deal directly with the manufacturer.
                        </li>
                        <li>
                            <strong>Advanced Capabilities</strong>
                            Blind/buried vias, 3mil trace/space, and rigorous impedance control for complex designs.
                        </li>
                        <li>
                            <strong>Global Shipping</strong>
                            Fast and reliable delivery via DHL/FedEx directly to your facility anywhere in the world.
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- 第五屏：Factory Tour & Capabilities (硬实力展示) -->
        <section class="bg-darker">
            <div class="container">
                <h2 class="section-title center">Factory Tour & Technical Capabilities</h2>
                <p class="text-content center" style="text-align: center; margin-bottom: 40px;">
                    Transparency is our promise. Explore our state-of-the-art facilities and review our comprehensive technical parameters below.
                </p>

                <!-- 工厂照片画廊 -->
                <div class="gallery-grid">
                    <div class="gallery-item">📸 Automated SMT Line</div>
                    <div class="gallery-item">📸 CNC Drilling Center</div>
                    <div class="gallery-item">📸 AOI Inspection</div>
                    <div class="gallery-item">📸 V-Cut & Routing</div>
                </div>

                <!-- 技术能力表 -->
                <div class="table-responsive">
                    <table class="tech-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Standard Capability</th>
                                <th>Advanced Capability</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Layer Count</td>
                                <td>1 - 20 Layers</td>
                                <td>Up to 40 Layers</td>
                            </tr>
                            <tr>
                                <td>Material Supported</td>
                                <td>FR4 (TG130, TG150)</td>
                                <td>High TG, Rogers, Aluminum, Flex</td>
                            </tr>
                            <tr>
                                <td>Min Trace / Space</td>
                                <td>4mil / 4mil (0.1mm)</td>
                                <td>3mil / 3mil (0.075mm)</td>
                            </tr>
                            <tr>
                                <td>Min Hole Size</td>
                                <td>0.2mm</td>
                                <td>0.1mm (Laser Drill)</td>
                            </tr>
                            <tr>
                                <td>Surface Finish</td>
                                <td>HASL (Lead-free), ENIG</td>
                                <td>OSP, Immersion Silver, Hard Gold</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
  </main>
</BaseLayout>
