    --d2-accent: #ff6b00;
    --d2-accent-glow: rgba(255, 107, 0, 0.15);
    --d2-accent-dim: #cc5500;
    --d2-green: #22c55e;
    --d2-green-bg: rgba(34, 197, 94, 0.12);
    --d2-amber: #f59e0b;
    --d2-amber-bg: rgba(245, 158, 11, 0.12);
    --d2-red: #ef4444;
    --d2-red-bg: rgba(239, 68, 68, 0.10);
    --d2-blue: #3b82f6;
    --d2-blue-bg: rgba(59, 130, 246, 0.10);
    --d2-purple: #a855f7;
    --d2-radius: 12px;
    --d2-radius-sm: 8px;
    --d2-radius-lg: 16px;
  }

  /* --- Layout utilities --- */
  .d2-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .d2-section-header {
    max-width: 800px;
    margin: 0 auto 48px;
    text-align: center;
  }

  .d2-section-header h2 {
    font-size: clamp(1.6rem, 3.2vw, 2.4rem);
    font-weight: 700;
    line-height: 1.25;
    margin: 12px 0 16px;
    color: var(--d2-text);
  }

  .d2-section-sub {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--d2-text-muted);
    max-width: 680px;
    margin: 0 auto;
  }

  .d2-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--d2-accent);
    background: var(--d2-accent-glow);
    padding: 5px 14px;
    border-radius: 20px;
    margin-bottom: 8px;
  }

  /* ================================================================
     SECTION 1 — OPENING / PROBLEM HERO
     ================================================================ */
  .d2-opening {
    padding: 80px 0 64px;
    background: var(--d2-bg);
    position: relative;
    overflow: hidden;
  }

  .d2-opening::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--d2-accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .d2-opening-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .d2-opening-text h1 {
    font-size: clamp(1.5rem, 3.5vw, 2.6rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 16px 0 20px;
    color: var(--d2-text);
  }

  .d2-opening-lead {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--d2-text);
    margin-bottom: 16px;
    font-weight: 500;
  }

  .d2-opening-text p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--d2-text-muted);
    margin-bottom: 14px;
  }

  .d2-opening-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 20px 0 24px;
  }

  .d2-opening-tags span {
    font-size: 0.8rem;
    color: var(--d2-text-muted);
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    padding: 4px 14px;
    border-radius: 20px;
  }

  .d2-opening-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .d2-image-card {
    border-radius: var(--d2-radius-lg);
    overflow: hidden;
    border: 1px solid var(--d2-border);
    background: var(--d2-bg-card);
  }

  .d2-image-card img {
    display: block;
    width: 100%;
    height: auto;
  }

  .d2-stats-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 16px;
  }

  .d2-stat-chip {
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    border-radius: var(--d2-radius-sm);
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
  }

  .d2-stat-chip strong {
    font-size: 1.3rem;
    color: var(--d2-accent);
    line-height: 1;
  }

  .d2-stat-chip span {
    font-size: 0.72rem;
    color: var(--d2-text-muted);
    margin-top: 4px;
  }

  /* --- Shared button styles --- */
  .d2-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    border-radius: var(--d2-radius-sm);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    border: none;
    line-height: 1.2;
  }

  .d2-btn-primary {
    background: var(--d2-accent);
    color: #fff;
  }

  .d2-btn-primary:hover {
    background: var(--d2-accent-dim);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(255, 107, 0, 0.3);
  }

  .d2-btn-outline {
    background: transparent;
    color: var(--d2-text);
    border: 1px solid var(--d2-border-light);
  }

  .d2-btn-outline:hover {
    border-color: var(--d2-accent);
    color: var(--d2-accent);
  }

  .d2-btn-block {
    width: 100%;
  }

  .d2-link-soft {
    color: var(--d2-text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.2s;
  }

  .d2-link-soft:hover {
    color: var(--d2-accent);
  }

  /* ================================================================
     SECTION 2 — THREE-WAY CROSSROADS
     ================================================================ */
  .d2-crossroads {
    padding: 80px 0;
    background: var(--d2-bg-alt);
  }

  .d2-crossroads-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr 1fr;
    gap: 16px;
    margin-bottom: 32px;
    align-items: start;
  }

  .d2-xroad {
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    border-radius: var(--d2-radius);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }

  .d2-xroad:hover {
    border-color: var(--d2-border-light);
    transform: translateY(-2px);
  }

  .d2-xroad-active {
    border-color: var(--d2-accent);
    box-shadow: 0 0 0 1px var(--d2-accent), 0 8px 30px var(--d2-accent-glow);
  }

  .d2-xroad-label {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 20px;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--d2-border);
  }

  .d2-xroad-arrow {
    font-size: 1.1rem;
    color: var(--d2-text-muted);
  }

  .d2-xroad-arrow-active {
    color: var(--d2-accent);
  }

  .d2-xroad-title {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--d2-text);
  }

  .d2-xroad-body {
    padding: 20px;
  }

  .d2-xroad-price {
    font-size: 0.8rem;
    color: var(--d2-text-muted);
    margin-bottom: 14px;
    line-height: 1.4;
  }

  .d2-xroad-body h4 {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--d2-text);
    margin: 0 0 10px;
  }

  .d2-xroad-list {
    list-style: none;
    padding: 0;
    margin: 0 0 14px;
  }

  .d2-xroad-list li {
    font-size: 0.82rem;
    color: var(--d2-text-muted);
    padding: 4px 0 4px 18px;
    position: relative;
    line-height: 1.45;
  }

  .d2-xroad-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--d2-border-light);
  }

  .d2-xroad-active .d2-xroad-list li::before {
    background: var(--d2-accent);
  }

  .d2-xroad-caveat {
    font-size: 0.78rem;
    color: var(--d2-text-muted);
    font-style: italic;
    line-height: 1.5;
    padding-top: 10px;
    border-top: 1px solid var(--d2-border);
  }

  .d2-xroad-footer {
    padding: 12px 20px;
    border-top: 1px solid var(--d2-border);
    text-align: center;
  }

  .d2-xroad-current {
    font-size: 0.78rem;
    color: var(--d2-accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .d2-insight-banner {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    background: var(--d2-blue-bg);
    border: 1px solid rgba(59, 130, 246, 0.25);
    border-radius: var(--d2-radius);
    padding: 20px 24px;
    max-width: 900px;
    margin: 0 auto;
  }

  .d2-insight-icon {
    font-size: 1.4rem;
    color: var(--d2-blue);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .d2-insight-banner div {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--d2-text-muted);
  }

  .d2-insight-banner strong {
    color: var(--d2-text);
  }

  /* ================================================================
     SECTION 3 — COST VS PERFORMANCE
     ================================================================ */
  .d2-costperf {
    padding: 80px 0;
    background: var(--d2-bg);
  }

  .d2-compare-strip {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 20px;
    align-items: start;
    margin-bottom: 36px;
  }

  .d2-compare-vs {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 60px;
  }

  .d2-compare-vs span {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--d2-text-muted);
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  .d2-compare-card {
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    border-radius: var(--d2-radius);
    overflow: hidden;
  }

  .d2-compare-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--d2-border);
  }

  .d2-compare-label {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--d2-text);
  }

  .d2-compare-cost {
    font-size: 0.8rem;
    color: var(--d2-text-muted);
  }

  .d2-compare-cost strong {
    color: var(--d2-text);
  }

  .d2-compare-body {
    padding: 16px 20px;
  }

  .d2-compare-metric {
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .d2-compare-metric:last-child {
    border-bottom: none;
  }

  .d2-metric-name {
    font-size: 0.82rem;
    color: var(--d2-text-muted);
    flex-shrink: 0;
  }

  .d2-metric-bar {
    flex: 1;
    min-width: 120px;
    height: 24px;
    background: var(--d2-bg);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }

  .d2-metric-fill {
    display: block;
    height: 100%;
    border-radius: 4px;
    font-size: 0.68rem;
    color: #fff;
    padding: 0 8px;
    line-height: 24px;
    white-space: nowrap;
  }

  .d2-fill-green { background: var(--d2-green); }
  .d2-fill-amber { background: var(--d2-amber); }

  .d2-metric-ticks {
    display: flex;
    gap: 3px;
  }

  .d2-tick {
    width: 20px;
    height: 8px;
    border-radius: 2px;
  }

  .d2-tick-fill { background: var(--d2-green); }
  .d2-tick-partial { background: var(--d2-amber); }
  .d2-tick-empty { background: var(--d2-border); }

  .d2-metric-note {
    font-size: 0.72rem;
    color: var(--d2-text-muted);
    flex-basis: 100%;
    margin-top: 2px;
  }

  .d2-metric-value {
    font-size: 0.85rem;
    font-weight: 600;
    padding: 2px 10px;
    border-radius: 4px;
  }

  .d2-value-good { color: var(--d2-green); background: var(--d2-green-bg); }
  .d2-value-medium { color: var(--d2-amber); background: var(--d2-amber-bg); }

  .d2-total-cost-box {
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    border-radius: var(--d2-radius);
    padding: 28px 32px;
    max-width: 800px;
    margin: 0 auto 36px;
  }

  .d2-total-cost-box h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--d2-accent);
    margin: 0 0 10px;
  }

  .d2-total-cost-box p {
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--d2-text-muted);
    margin-bottom: 8px;
  }

  .d2-volume-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .d2-volume-card {
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    border-radius: var(--d2-radius);
    padding: 24px;
    transition: border-color 0.2s;
  }

  .d2-volume-card:hover {
    border-color: var(--d2-border-light);
  }

  .d2-volume-active {
    border-color: var(--d2-accent);
    box-shadow: 0 0 0 1px var(--d2-accent);
  }

  .d2-volume-qty {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--d2-accent);
    margin-bottom: 8px;
  }

  .d2-volume-card h4 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--d2-text);
    margin: 0 0 10px;
  }

  .d2-volume-card p {
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--d2-text-muted);
    margin: 0;
  }

  /* ================================================================
     SECTION 4 — DFM PLAYBOOK
     ================================================================ */
  .d2-dfm {
    padding: 80px 0;
    background: var(--d2-bg-alt);
  }

  .d2-dfm-grid {
    display: grid;
    gap: 16px;
    max-width: 900px;
    margin: 0 auto 32px;
  }

  .d2-dfm-card {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 20px;
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    border-radius: var(--d2-radius);
    padding: 24px;
  }

  .d2-dfm-num {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--d2-accent);
    line-height: 1;
    opacity: 0.6;
  }

  .d2-dfm-content h4 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--d2-text);
    margin: 0 0 8px;
  }

  .d2-dfm-desc {
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--d2-text-muted);
    margin-bottom: 12px;
  }

  .d2-dfm-dos {
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--d2-text-muted);
    margin-bottom: 6px;
    padding: 6px 10px;
    border-radius: 6px;
    background: rgba(255,255,255,0.02);
  }

  .d2-dfm-do-label {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1px 8px;
    border-radius: 3px;
    margin-right: 6px;
  }

  .d2-dfm-do { color: var(--d2-green); background: var(--d2-green-bg); }
  .d2-dfm-dont { color: var(--d2-red); background: var(--d2-red-bg); }

  .d2-dfm-cta {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .d2-dfm-cta p {
    font-size: 0.9rem;
    color: var(--d2-text-muted);
    margin-bottom: 16px;
  }

  /* ================================================================
     SECTION 5 — SPEC EXPLORER
     ================================================================ */
  .d2-specs {
    padding: 80px 0;
    background: var(--d2-bg);
  }

  .d2-specs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .d2-spec-card {
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    border-radius: var(--d2-radius);
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .d2-spec-card:hover {
    border-color: var(--d2-border-light);
  }

  .d2-spec-top {
    padding: 16px 20px;
    border-bottom: 1px solid var(--d2-border);
    background: rgba(255,255,255,0.02);
  }

  .d2-spec-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--d2-text);
    margin: 0 0 4px;
  }

  .d2-spec-default {
    font-size: 0.72rem;
    color: var(--d2-text-muted);
  }

  .d2-spec-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    padding: 10px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    align-items: center;
  }

  .d2-spec-row:last-of-type {
    border-bottom: none;
  }

  .d2-spec-option {
    font-size: 0.82rem;
    color: var(--d2-text);
    font-weight: 500;
  }

  .d2-spec-cost {
    font-size: 0.78rem;
    color: var(--d2-amber);
    font-weight: 600;
    white-space: nowrap;
  }

  .d2-spec-when {
    font-size: 0.75rem;
    color: var(--d2-text-muted);
    grid-column: 1 / -1;
    line-height: 1.5;
  }

  .d2-spec-tip {
    padding: 12px 20px;
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--d2-text-muted);
    background: var(--d2-accent-glow);
    border-top: 1px solid rgba(255, 107, 0, 0.15);
  }

  .d2-spec-tip strong {
    color: var(--d2-accent);
  }

  /* ================================================================
     SECTION 6 — STACKUP EXPLORER
     ================================================================ */
  .d2-stackup {
    padding: 80px 0;
    background: var(--d2-bg-alt);
  }

  .d2-stackup-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .d2-stackup-diagram {
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    border-radius: var(--d2-radius);
    padding: 32px 24px;
  }

  .d2-stackup-top {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .d2-stackup-layer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    border-radius: 6px;
    font-size: 0.82rem;
  }

  .d2-stackup-solder {
    background: rgba(59, 130, 246, 0.12);
    border: 1px solid rgba(59, 130, 246, 0.2);
    color: var(--d2-text-muted);
  }

  .d2-stackup-cu {
    background: var(--d2-amber-bg);
    border: 1px solid rgba(245, 158, 11, 0.25);
  }

  .d2-stackup-core {
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.15);
    color: var(--d2-text-muted);
  }

  .d2-stackup-label {
    font-weight: 600;
    color: var(--d2-text);
  }

  .d2-stackup-detail {
    font-size: 0.72rem;
    color: var(--d2-text-muted);
  }

  .d2-stackup-via-note {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-top: 20px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.03);
    border-radius: 6px;
    font-size: 0.8rem;
    color: var(--d2-text-muted);
    border: 1px dashed var(--d2-border);
  }

  .d2-stackup-via-icon {
    color: var(--d2-accent);
    font-size: 1rem;
  }

  .d2-stackup-notes {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .d2-stackup-note {
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
    border-radius: var(--d2-radius);
    padding: 20px;
  }

  .d2-stackup-note h4 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--d2-text);
    margin: 0 0 8px;
  }

  .d2-stackup-note p {
    font-size: 0.84rem;
    line-height: 1.6;
    color: var(--d2-text-muted);
    margin: 0;
  }

  /* ================================================================
     SECTION 7 — APPLICATIONS
     ================================================================ */
  .d2-apps {
    padding: 80px 0;
    background: var(--d2-bg);
  }

  .d2-apps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .d2-app-card {
    background: var(--d2-bg-card);
    border: 1px solid var(--d2-border);
