  .f4-arch-tag {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
  }
  .f4-arch-tag-green {
    color: var(--f4-green);
    background: var(--f4-green-bg);
  }
  .f4-arch-tag-blue {
    color: var(--f4-blue);
    background: var(--f4-blue-bg);
  }
  .f4-arch-tag-amber {
    color: var(--f4-amber);
    background: var(--f4-amber-bg);
  }
  .f4-arch-diagram {
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .f4-layer-row {
    padding: 8px 14px;
    border-radius: 4px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--f4-text);
  }
  .f4-l-signal {
    background: rgba(6, 182, 212, 0.15);
    border: 1px solid rgba(6, 182, 212, 0.3);
    color: var(--f4-cyan);
  }
  .f4-l-prepreg {
    background: rgba(148, 160, 184, 0.08);
    border: 1px dashed var(--f4-border);
    color: var(--f4-text-dim);
    font-weight: 400;
    font-size: 0.75rem;
    padding: 5px 14px;
  }
  .f4-l-prepreg-thick {
    background: rgba(245, 158, 11, 0.08);
    border-color: rgba(245, 158, 11, 0.2);
    color: var(--f4-amber);
  }
  .f4-l-plane {
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.25);
    color: var(--f4-green);
  }
  .f4-l-power {
    background: rgba(168, 85, 247, 0.12);
    border-color: rgba(168, 85, 247, 0.25);
    color: var(--f4-purple);
  }
  .f4-l-core {
    background: rgba(148, 160, 184, 0.06);
    border: 1px solid var(--f4-border);
    color: var(--f4-text-dim);
    font-weight: 400;
  }
  .f4-arch-specs {
    padding: 0 24px 16px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }
  .f4-arch-spec {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 5px 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .f4-as-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--f4-text-dim);
    min-width: 150px;
  }
  .f4-as-value {
    font-size: 0.88rem;
    color: var(--f4-text-muted);
    line-height: 1.5;
  }
  .f4-as-baseline {
    color: var(--f4-green);
    font-weight: 600;
  }
  .f4-as-premium {
    color: var(--f4-amber);
    font-weight: 600;
  }
  .f4-arch-note {
    padding: 14px 24px;
    background: rgba(255,255,255,0.02);
    border-top: 1px solid var(--f4-border);
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--f4-text-dim);
  }
  .f4-arch-note strong {
    color: var(--f4-text-muted);
  }
  .f4-arch-decision {
    background: var(--f4-bg-card);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius);
    padding: 28px 32px;
  }
  .f4-arch-decision h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--f4-text);
    margin-bottom: 16px;
  }
  .f4-arch-decision ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }
  .f4-arch-decision li {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--f4-text-muted);
    padding-left: 16px;
    border-left: 2px solid var(--f4-accent);
  }

  /* ==================================================================
     SECTION 3 — IMPEDANCE ENGINEERING
     ================================================================== */
  .f4-impedance {
    padding: 80px 0;
    background: var(--f4-bg);
  }
  .f4-imp-methodology {
    display: grid;
    gap: 28px;
    margin-bottom: 48px;
  }
  .f4-imp-step {
    background: var(--f4-bg-card);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius);
    padding: 24px 28px;
    position: relative;
  }
  .f4-imp-num {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--f4-accent);
    display: block;
    margin-bottom: 6px;
  }
  .f4-imp-step h4 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--f4-text);
    margin-bottom: 12px;
  }
  .f4-imp-step p {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--f4-text-muted);
    margin-bottom: 10px;
  }
  .f4-imp-formula {
    background: var(--f4-bg);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius-sm);
    padding: 14px 20px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.85rem;
    color: var(--f4-cyan);
    margin: 12px 0;
    overflow-x: auto;
  }
  .f4-imp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 12px 0;
  }
  .f4-imp-cell {
    background: var(--f4-bg);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius-sm);
    padding: 16px 20px;
  }
  .f4-imp-cell strong {
    font-size: 0.9rem;
    color: var(--f4-text);
    display: block;
    margin-bottom: 8px;
  }
  .f4-imp-cell ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .f4-imp-cell li {
    font-size: 0.82rem;
    color: var(--f4-text-muted);
    padding: 3px 0;
    padding-left: 12px;
    position: relative;
  }
  .f4-imp-cell li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--f4-accent);
  }
  .f4-imp-note {
    font-size: 0.82rem !important;
    color: var(--f4-text-dim) !important;
    font-style: italic;
  }
  .f4-imp-targets h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--f4-text);
    margin-bottom: 16px;
  }
  .f4-imp-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: var(--f4-radius-sm);
    overflow: hidden;
    border: 1px solid var(--f4-border);
  }
  .f4-imp-table th {
    background: var(--f4-bg-alt);
    color: var(--f4-text-dim);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--f4-border);
  }
  .f4-imp-table td {
    padding: 11px 16px;
    font-size: 0.85rem;
    color: var(--f4-text-muted);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .f4-imp-table tr:last-child td {
    border-bottom: none;
  }
  .f4-imp-table tr:hover td {
    background: rgba(255,255,255,0.02);
  }
  .f4-imp-table-note {
    font-size: 0.78rem !important;
    color: var(--f4-text-dim) !important;
    margin-top: 12px !important;
  }

  /* ==================================================================
     SECTION 4 — MATERIAL SELECTION
     ================================================================== */
  .f4-materials {
    padding: 80px 0;
    background: var(--f4-bg-alt);
  }
  .f4-mat-tabs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 40px;
  }
  .f4-mat-card {
    background: var(--f4-bg-card);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius);
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .f4-mat-card:hover {
    border-color: var(--f4-border-light);
  }
  .f4-mat-highlight {
    border-color: var(--f4-accent);
    box-shadow: 0 0 0 1px var(--f4-accent), 0 4px 24px var(--f4-accent-glow);
  }
  .f4-mat-top {
    padding: 20px 24px;
    border-bottom: 1px solid var(--f4-border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }
  .f4-mat-top h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--f4-text);
    margin: 0;
    flex: 1;
  }
  .f4-mat-cost {
    font-size: 0.78rem;
    color: var(--f4-text-dim);
    font-weight: 600;
  }
  .f4-mat-tag {
    font-size: 0.68rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    color: var(--f4-text-dim);
    background: var(--f4-bg);
    border: 1px solid var(--f4-border);
  }
  .f4-mat-specs {
    padding: 16px 24px;
  }
  .f4-mat-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 7px 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .f4-mat-prop {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--f4-text-dim);
  }
  .f4-mat-val {
    font-size: 0.85rem;
    color: var(--f4-text-muted);
    text-align: right;
  }
  .f4-mat-rec,
  .f4-mat-caution,
  .f4-mat-note {
    padding: 14px 24px;
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--f4-text-dim);
  }
  .f4-mat-rec {
    background: rgba(34, 197, 94, 0.04);
    border-top: 1px solid var(--f4-border);
  }
  .f4-mat-caution {
    background: rgba(239, 68, 68, 0.04);
    border-top: 1px solid var(--f4-border);
  }
  .f4-mat-note {
    background: rgba(59, 130, 246, 0.04);
    border-top: 1px solid var(--f4-border);
  }
  .f4-mat-decision {
    background: var(--f4-bg-card);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius);
    padding: 24px 28px;
  }
  .f4-mat-decision h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--f4-text);
    margin-bottom: 16px;
  }
  .f4-mat-flow {
    display: grid;
    gap: 10px;
  }
  .f4-mat-flow-item {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding: 8px 0;
  }
  .f4-flow-q {
    font-size: 0.85rem;
    color: var(--f4-text-muted);
    flex: 1;
    min-width: 200px;
  }
  .f4-flow-a {
    font-size: 0.82rem;
    font-weight: 600;
    padding: 5px 14px;
    border-radius: 20px;
  }
  .f4-flow-yes {
    color: var(--f4-green);
    background: var(--f4-green-bg);
  }
  .f4-flow-rogers {
    color: var(--f4-amber);
    background: var(--f4-amber-bg);
  }

  /* ==================================================================
     SECTION 5 — THERMAL MANAGEMENT
     ================================================================== */
  .f4-thermal {
    padding: 80px 0;
    background: var(--f4-bg);
  }
  .f4-thermal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .f4-thermal-card {
    background: var(--f4-bg-card);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius);
    padding: 24px 24px;
  }
  .f4-thermal-wide {
    grid-column: 1 / -1;
  }
  .f4-thermal-card h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--f4-text);
    margin-bottom: 12px;
  }
  .f4-thermal-card p {
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--f4-text-muted);
    margin-bottom: 14px;
  }
  .f4-thermal-data {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .f4-td-label {
    font-size: 0.8rem;
    color: var(--f4-text-dim);
  }
  .f4-td-value {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--f4-text);
  }
  .f4-thermal-note {
    font-size: 0.8rem !important;
    color: var(--f4-text-dim) !important;
    font-style: italic;
    margin-top: 8px !important;
  }
  .f4-thermal-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: var(--f4-radius-sm);
    overflow: hidden;
    border: 1px solid var(--f4-border);
    margin: 12px 0;
  }
  .f4-thermal-table th {
    background: var(--f4-bg-alt);
    color: var(--f4-text-dim);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--f4-border);
  }
  .f4-thermal-table td {
    padding: 10px 14px;
    font-size: 0.82rem;
    color: var(--f4-text-muted);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .f4-thermal-table tr:last-child td {
    border-bottom: none;
  }

  /* ==================================================================
     SECTION 6 — DFM CODE
     ================================================================== */
  .f4-dfm {
    padding: 80px 0;
    background: var(--f4-bg-alt);
  }
  .f4-dfm-list {
    display: grid;
    gap: 20px;
    margin-bottom: 40px;
  }
  .f4-dfm-rule {
    background: var(--f4-bg-card);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius);
    display: grid;
    grid-template-columns: 140px 1fr;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .f4-dfm-rule:hover {
    border-color: var(--f4-border-light);
  }
  .f4-dfm-num {
    background: var(--f4-bg);
    border-right: 1px solid var(--f4-border);
    padding: 20px 16px;
    font-size: 0.7rem;
    font-weight: 700;
    font-family: 'Courier New', Courier, monospace;
    color: var(--f4-accent);
    letter-spacing: 0.02em;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  .f4-dfm-body {
    padding: 20px 24px;
  }
  .f4-dfm-body h4 {
    font-size: 0.96rem;
    font-weight: 700;
    color: var(--f4-text);
    margin-bottom: 10px;
  }
  .f4-dfm-body p {
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--f4-text-muted);
    margin-bottom: 12px;
  }
  .f4-dfm-dos {
    font-size: 0.82rem;
    line-height: 1.6;
    padding: 6px 0 6px 16px;
    position: relative;
  }
  .f4-dfm-do {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--f4-green);
    background: var(--f4-green-bg);
    padding: 2px 8px;
    border-radius: 4px;
    margin-right: 6px;
  }
  .f4-dfm-dont {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--f4-red);
    background: rgba(239, 68, 68, 0.12);
    padding: 2px 8px;
    border-radius: 4px;
    margin-right: 6px;
  }
  .f4-dfm-cta {
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
    padding: 28px 32px;
    background: var(--f4-bg-card);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius);
  }
  .f4-dfm-cta p {
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--f4-text-muted);
    margin-bottom: 18px;
  }

  /* ==================================================================
     SECTION 7 — COST TRANSPARENCY
     ================================================================== */
  .f4-cost {
    padding: 80px 0;
    background: var(--f4-bg);
  }
  .f4-cost-diagram {
    margin-bottom: 40px;
  }
  .f4-cost-bar {
    display: flex;
    border-radius: var(--f4-radius-sm);
    overflow: hidden;
    height: 48px;
    font-size: 0.72rem;
    font-weight: 600;
  }
  .f4-cost-bar .f4-cost-segment {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--f4-text);
    padding: 0 8px;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: opacity 0.2s;
  }
  .f4-cost-bar .f4-cost-segment:hover {
    opacity: 0.85;
  }
  .f4-cost-material { background: #1e40af; }
  .f4-cost-lam { background: #166534; }
  .f4-cost-drill { background: #7c3aed; }
  .f4-cost-plating { background: #b45309; }
  .f4-cost-test { background: #0f766e; }
  .f4-cost-other { background: #4a5568; }
  .f4-cost-details {
    display: grid;
    gap: 20px;
    margin-bottom: 40px;
  }
  .f4-cost-item {
    background: var(--f4-bg-card);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius);
    padding: 24px 28px;
  }
  .f4-ci-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 10px;
  }
  .f4-ci-header h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--f4-text);
    margin: 0;
  }
  .f4-ci-pct {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--f4-accent);
  }
  .f4-cost-item p {
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--f4-text-muted);
    margin-bottom: 10px;
  }
  .f4-ci-levers {
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--f4-text-dim);
    background: var(--f4-bg);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius-sm);
    padding: 10px 14px;
  }
  .f4-cost-summary {
    background: var(--f4-bg-card);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius);
    padding: 28px 28px;
  }
  .f4-cost-summary h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--f4-text);
    margin-bottom: 16px;
  }
  .f4-cost-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: var(--f4-radius-sm);
    overflow: hidden;
    border: 1px solid var(--f4-border);
    margin-bottom: 12px;
  }
  .f4-cost-table th {
    background: var(--f4-bg-alt);
    color: var(--f4-text-dim);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--f4-border);
  }
  .f4-cost-table td {
    padding: 10px 14px;
    font-size: 0.83rem;
    color: var(--f4-text-muted);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .f4-cost-table tr:last-child td {
    border-bottom: none;
  }
  .f4-cost-table tr:hover td {
    background: rgba(255,255,255,0.02);
  }
  .f4-cost-table tr:nth-child(3) td {
    color: var(--f4-text);
    font-weight: 600;
  }
  .f4-cost-note {
    font-size: 0.78rem;
    color: var(--f4-text-dim);
    line-height: 1.5;
  }

  /* ==================================================================
     SECTION 8 — APPLICATIONS
     ================================================================== */
  .f4-apps {
    padding: 80px 0;
    background: var(--f4-bg-alt);
  }
  .f4-apps-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .f4-app-card {
    background: var(--f4-bg-card);
    border: 1px solid var(--f4-border);
    border-radius: var(--f4-radius);
    padding: 24px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .f4-app-card:hover {
    border-color: var(--f4-border-light);
    transform: translateY(-2px);
  }
  .f4-app-card h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--f4-text);
    margin-bottom: 10px;
  }
  .f4-app-card p {
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--f4-text-muted);
  }

  /* ==================================================================
     SECTION 9 — ENGINEERING CONSULTATION (RFQ)
     ================================================================== */
  .f4-consult {
    padding: 80px 0;
    background: var(--f4-bg);
  }
  .f4-consult-layout {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 48px;
