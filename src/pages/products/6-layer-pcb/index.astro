    padding: 20px 16px;
    background: rgba(0, 255, 65, 0.04);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .s6-compare-signal h3 {
    font-size: 0.95rem;
    color: #ffffff;
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .s6-compare-speed {
    font-size: 0.78rem;
    color: var(--pcb-glow, #00ff41);
    font-weight: 500;
  }

  .s6-compare-4layer,
  .s6-compare-6layer {
    padding: 20px 20px;
  }

  .s6-compare-4layer {
    border-right: 1px solid rgba(255, 255, 255, 0.05);
  }

  .s6-compare-heading {
    display: block;
    font-weight: 700;
    font-size: 0.85rem;
    color: #ffffff;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .s6-compare-4layer .s6-compare-heading {
    color: #c89070;
  }

  .s6-compare-6layer .s6-compare-heading {
    color: var(--pcb-glow, #00ff41);
  }

  .s6-compare-4layer p,
  .s6-compare-6layer p {
    font-size: 0.88rem;
    color: #a0b8a8;
    line-height: 1.6;
  }

  .s6-compare-decision {
    max-width: 860px;
    margin: 48px auto 0 auto;
    padding: 32px;
    background: rgba(0, 255, 65, 0.04);
    border: 1px solid rgba(0, 255, 65, 0.12);
    border-radius: 12px;
  }

  .s6-compare-decision h4 {
    color: #ffffff;
    font-size: 1.15rem;
    margin-bottom: 20px;
  }

  .s6-compare-checklist {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .s6-check-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.92rem;
    color: #b0c8b8;
    line-height: 1.5;
  }

  .s6-check-icon {
    color: var(--pcb-glow, #00ff41);
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .s6-compare-note {
    margin-top: 20px;
    color: var(--pcb-glow, #00ff41);
    font-size: 0.95rem;
    font-weight: 500;
    border-top: 1px solid rgba(0, 255, 65, 0.15);
    padding-top: 16px;
  }

  /* ========================================================================
     SECTION 3 — SEQUENTIAL LAMINATION
     ======================================================================== */
  .s6-lamination {
    background: rgba(10, 30, 18, 0.30) !important;
  }

  .s6-lam-diagram {
    max-width: 780px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .s6-lam-step {
    display: grid;
    grid-template-columns: 40px 1fr 160px;
    gap: 20px;
    align-items: center;
    width: 100%;
    padding: 20px;
    background: rgba(0, 0, 0, 0.25);
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .s6-lam-num {
    width: 40px;
    height: 40px;
    background: rgba(0, 255, 65, 0.10);
    border: 1px solid rgba(0, 255, 65, 0.25);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--pcb-glow, #00ff41);
  }

  .s6-lam-content h4 {
    color: #ffffff;
    font-size: 1.05rem;
    margin-bottom: 8px;
  }

  .s6-lam-content p {
    color: #a0b8a8;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .s6-lam-arrow {
    text-align: center;
    color: var(--pcb-glow, #00ff41);
    font-size: 1.4rem;
    opacity: 0.6;
    padding: 4px 0;
    font-weight: 300;
  }

  /* Mini stackup visualization */
  .s6-lam-preview {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 8px;
    background: rgba(0, 0, 0, 0.30);
    border-radius: 6px;
  }

  .s6-lam-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .s6-lam-pregap {
    height: 4px;
  }

  .s6-lam-mini-layer {
    display: block;
    width: 120px;
    padding: 4px 8px;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 3px;
  }

  .s6-lam-cu {
    background: rgba(0, 255, 65, 0.12);
    color: var(--pcb-glow, #00ff41);
    border: 1px solid rgba(0, 255, 65, 0.20);
  }

  .s6-lam-core {
    background: #1a3a1a;
    color: #8ab88a;
    border: 1px solid #2a4a2a;
  }

  .s6-lam-prepreg {
    background: rgba(200, 180, 120, 0.10);
    color: #b8a878;
    border: 1px solid rgba(200, 180, 120, 0.20);
    font-style: italic;
  }

  /* Process notes */
  .s6-lam-process-note {
    max-width: 860px;
    margin: 40px auto 0 auto;
  }

  .s6-lam-note-card {
    padding: 28px 32px;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
  }

  .s6-lam-note-card h4 {
    color: #ffffff;
    font-size: 1.1rem;
    margin-bottom: 20px;
  }

  .s6-lam-impacts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .s6-lam-impacts li {
    font-size: 0.92rem;
    color: #a0b8a8;
    line-height: 1.6;
    padding-left: 0;
    position: relative;
  }

  .s6-lam-impacts li strong {
    color: #d0e0d4;
  }

  /* ========================================================================
     SECTION 4 — VIA ARCHITECTURE
     ======================================================================== */
  .s6-via-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .s6-via-card {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
  }

  .s6-via-card-accent {
    border-color: rgba(60, 160, 240, 0.25);
  }

  .s6-via-visual {
    padding: 20px 20px 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .s6-via-symbol {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 10px 0;
  }

  .s6-via-bar {
    display: block;
    width: 60px;
    height: 6px;
    background: var(--pcb-glow, #00ff41);
    border-radius: 3px;
    opacity: 0.7;
  }

  .s6-via-bar-inactive {
    background: rgba(255, 255, 255, 0.10);
    opacity: 0.3;
  }

  .s6-via-label-symbol {
    font-size: 0.78rem;
    color: #a0b8a8;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .s6-via-body {
    padding: 16px 24px 24px 24px;
  }

  .s6-via-body h3 {
    color: #ffffff;
    font-size: 1.15rem;
    margin-bottom: 8px;
  }

  .s6-via-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 3px 10px;
    border-radius: 12px;
    margin-bottom: 14px;
  }

  .s6-via-tag-default {
    background: rgba(255, 255, 255, 0.08);
    color: #b0c8b8;
  }

  .s6-via-tag-blue {
    background: rgba(60, 160, 240, 0.12);
    color: #60b8ff;
    border: 1px solid rgba(60, 160, 240, 0.20);
  }

  .s6-via-tag-amber {
    background: rgba(240, 180, 60, 0.12);
    color: #f0c040;
    border: 1px solid rgba(240, 180, 60, 0.20);
  }

  .s6-via-specs {
    margin: 14px 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .s6-via-spec {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .s6-via-spec-label {
    font-size: 0.82rem;
    color: #9ab0a2;
  }

  .s6-via-spec-val {
    font-size: 0.85rem;
    color: #c8ddd0;
    font-weight: 500;
  }

  .s6-via-note {
    font-size: 0.88rem;
    color: #a0b8a8;
    line-height: 1.55;
    margin-top: 12px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 6px;
  }

  .s6-via-note strong {
    color: #d0e0d4;
  }

  .s6-via-caution {
    border-left: 2px solid #c89070;
    background: rgba(200, 144, 112, 0.06);
    margin-top: 8px;
  }

  /* ========================================================================
     SECTION 5 — STACKUP ARCHITECTURES (Accordion)
     ======================================================================== */
  .s6-architectures {
    background: rgba(10, 30, 18, 0.50) !important;
  }

  .s6-arch-accordion {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .s6-arch-panel {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    overflow: hidden;
  }

  .s6-arch-summary {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 24px;
    cursor: pointer;
    list-style: none;
  }

  .s6-arch-summary::-webkit-details-marker {
    display: none;
  }

  .s6-arch-summary:hover {
    background: rgba(0, 255, 65, 0.03);
  }

  .s6-arch-num {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--pcb-glow, #00ff41);
    flex-shrink: 0;
    min-width: 100px;
  }

  .s6-arch-title {
    font-size: 1.0rem;
    color: #ffffff;
    font-weight: 600;
    flex: 1;
  }

  .s6-arch-tag {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 3px 10px;
    border-radius: 12px;
    flex-shrink: 0;
  }

  .s6-arch-tag-green {
    background: rgba(0, 255, 65, 0.10);
    color: var(--pcb-glow, #00ff41);
  }

  .s6-arch-tag-blue {
    background: rgba(60, 160, 240, 0.10);
    color: #60b8ff;
  }

  .s6-arch-tag-amber {
    background: rgba(240, 180, 60, 0.10);
    color: #f0c040;
  }

  .s6-arch-toggle {
    font-size: 0.8rem;
    color: #a0b8a8;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .s6-arch-panel[open] .s6-arch-toggle {
    transform: rotate(180deg);
  }

  .s6-arch-detail {
    padding: 0 24px 24px 24px;
  }

  .s6-arch-detail-grid {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 28px;
    align-items: start;
  }

  .s6-arch-diagram {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .s6-arch-layer {
    padding: 8px 12px;
    font-size: 0.78rem;
    border-radius: 4px;
    line-height: 1.3;
  }

  .s6-arch-signal {
    background: rgba(0, 255, 65, 0.08);
    color: #b0e0b8;
    border: 1px solid rgba(0, 255, 65, 0.12);
  }

  .s6-arch-plane {
    background: rgba(60, 160, 240, 0.08);
    color: #80c0f0;
    border: 1px solid rgba(60, 160, 240, 0.12);
  }

  .s6-arch-power {
    border-color: rgba(240, 180, 60, 0.20);
    background: rgba(240, 180, 60, 0.08);
    color: #f0c860;
  }

  .s6-arch-core {
    background: #1a3a1a;
    color: #6a9a6a;
    border: 1px solid #2a4a2a;
    padding: 3px 12px;
    font-size: 0.75rem;
  }

  .s6-arch-prepreg {
    background: rgba(200, 180, 120, 0.06);
    color: #a8986a;
    border: 1px solid rgba(200, 180, 120, 0.10);
    padding: 3px 12px;
    font-size: 0.75rem;
    font-style: italic;
  }

  .s6-arch-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .s6-arch-specs {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 12px 16px;
    background: rgba(0, 0, 0, 0.20);
    border-radius: 8px;
  }

  .s6-arch-spec-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    padding: 4px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .s6-arch-spec-row:last-child {
    border-bottom: none;
  }

  .s6-arch-spec-label {
    color: #9ab0a2;
  }

  .s6-arch-spec-val {
    color: #c8ddd0;
    font-weight: 500;
  }

  .s6-arch-baseline {
    color: var(--pcb-glow, #00ff41);
  }

  .s6-arch-premium {
    color: #f0c040;
  }

  .s6-arch-pros h4,
  .s6-arch-cons h4 {
    font-size: 0.88rem;
    color: #ffffff;
    margin-bottom: 8px;
  }

  .s6-arch-pros ul,
  .s6-arch-cons ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .s6-arch-pros li,
  .s6-arch-cons li {
    font-size: 0.88rem;
    color: #a0b8a8;
    line-height: 1.55;
    padding: 4px 0;
    padding-left: 16px;
    position: relative;
  }

  .s6-arch-pros li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--pcb-glow, #00ff41);
    font-weight: 700;
  }

  .s6-arch-cons li::before {
    content: '\2212';
    position: absolute;
    left: 0;
    color: #c89070;
    font-weight: 700;
  }

  .s6-arch-bestfor {
    font-size: 0.88rem;
    color: #a0b8a8;
    padding: 12px 16px;
    background: rgba(0, 255, 65, 0.04);
    border-radius: 8px;
    line-height: 1.55;
  }

  .s6-arch-bestfor strong {
    color: #ffffff;
  }

  .s6-arch-recommendation {
    max-width: 860px;
    margin: 36px auto 0 auto;
    padding: 28px 32px;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
  }

  .s6-arch-recommendation h4 {
    color: #ffffff;
    font-size: 1.05rem;
    margin-bottom: 18px;
  }

  .s6-arch-flow {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .s6-arch-flow-item {
    padding: 14px 18px;
    background: rgba(0, 0, 0, 0.20);
    border-radius: 8px;
    border-left: 3px solid var(--pcb-glow, #00ff41);
  }

  .s6-flow-q {
    display: block;
    font-size: 0.92rem;
    color: #b0c8b8;
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .s6-flow-q strong {
    color: #ffffff;
  }

  .s6-flow-a {
    display: block;
    font-size: 0.92rem;
    color: var(--pcb-glow, #00ff41);
    font-weight: 600;
  }

  /* ========================================================================
     SECTION 6 — DFM HANDBOOK
     ======================================================================== */
  .s6-dfm {
    background: rgba(10, 30, 18, 0.30) !important;
  }

  .s6-dfm-list {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .s6-dfm-item {
    display: grid;
    grid-template-columns: 50px 1fr;
    gap: 20px;
    padding: 24px;
    background: rgba(0, 0, 0, 0.20);
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .s6-dfm-num {
    font-size: 1.6rem;
    font-weight: 700;
    color: rgba(0, 255, 65, 0.45);
    line-height: 1;
  }

  .s6-dfm-body h4 {
    color: #ffffff;
    font-size: 1.1rem;
    margin-bottom: 10px;
  }

  .s6-dfm-desc {
    font-size: 0.92rem;
    color: #a0b8a8;
    line-height: 1.65;
    margin-bottom: 14px;
  }

  .s6-dfm-rules {
    font-size: 0.88rem;
    line-height: 1.55;
    padding: 8px 12px;
    margin-bottom: 6px;
    border-radius: 6px;
  }

  .s6-dfm-do {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #05140a;
    background: var(--pcb-glow, #00ff41);
    padding: 1px 7px;
    border-radius: 4px;
    margin-right: 6px;
  }

  .s6-dfm-dont {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #fff;
    background: rgba(200, 144, 112, 0.40);
    padding: 1px 7px;
    border-radius: 4px;
    margin-right: 6px;
  }

  .s6-dfm-desc .s6-dfm-do,
  .s6-dfm-desc .s6-dfm-dont {
    margin-right: 4px;
  }

  .s6-dfm-outro {
    max-width: 860px;
    margin: 32px auto 0 auto;
    text-align: center;
    font-size: 1.0rem;
    color: #b0c8b8;
    line-height: 1.6;
  }

  .s6-dfm-outro a {
    color: var(--pcb-glow, #00ff41);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ========================================================================
     SECTION 7 — SPEC REFERENCE
     ======================================================================== */
  .s6-specs {
    background: rgba(10, 30, 18, 0.50) !important;
  }

  .s6-specs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
    max-width: 1060px;
    margin: 0 auto;
  }

  .s6-spec-category {
    padding: 24px;
    background: rgba(0, 0, 0, 0.20);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
  }

  .s6-spec-category h3 {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pcb-glow, #00ff41);
    margin-bottom: 16px;
    font-weight: 700;
  }

  .s6-spec-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .s6-spec-term {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    padding-bottom: 12px;
  }

  .s6-spec-term:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .s6-spec-term dt {
    font-size: 0.90rem;
    color: #ffffff;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .s6-spec-term dd {
    font-size: 0.85rem;
    color: #a0b8a8;
    line-height: 1.5;
    margin: 0;
  }

  .s6-spec-fallback {
    max-width: 860px;
    margin: 32px auto 0 auto;
    text-align: center;
    font-size: 0.95rem;
    color: #a0b8a8;
  }

  .s6-spec-fallback a {
    color: var(--pcb-glow, #00ff41);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ========================================================================
     SECTION 8 — ENGINEERING CONSULTATION / FORM
     ======================================================================== */
  .s6-consult {
    background: rgba(10, 30, 18, 0.40) !important;
  }

  .s6-consult-layout {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 48px;
    align-items: start;
  }

  .s6-consult-copy h2 {
    font-size: 1.8rem;
    color: #ffffff;
    margin: 16px 0 20px 0;
    line-height: 1.25;
  }

  .s6-consult-copy p {
    font-size: 0.95rem;
    color: #a0b8a8;
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .s6-consult-list {
    list-style: none;
    padding: 0;
    margin: 20px 0;
  }

  .s6-consult-list li {
    padding: 6px 0;
    padding-left: 20px;
    position: relative;
    font-size: 0.92rem;
    color: #b0c8b8;
    line-height: 1.5;
  }

  .s6-consult-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 13px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--pcb-glow, #00ff41);
    opacity: 0.5;
  }

  .s6-consult-note {
