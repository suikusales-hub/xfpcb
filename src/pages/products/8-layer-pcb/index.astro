  .s8-adv-row {
    display: grid;
    grid-template-columns: 180px 1fr 1fr;
    border-bottom: 1px solid rgba(0, 255, 65, 0.1);
  }

  .s8-adv-row:last-child {
    border-bottom: none;
  }

  .s8-adv-axis {
    padding: 20px;
    background: rgba(26, 66, 37, 0.4);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .s8-adv-axis h3 {
    color: #fff;
    font-size: 1.05rem;
    margin: 0 0 6px;
    line-height: 1.2;
  }

  .s8-adv-axis-tag {
    font-size: 0.75rem;
    color: var(--pcb-glow);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
  }

  .s8-adv-6l,
  .s8-adv-8l {
    padding: 20px;
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--text-main);
  }

  .s8-adv-6l {
    background: rgba(0, 0, 0, 0.15);
    border-right: 1px solid rgba(0, 255, 65, 0.08);
  }

  .s8-adv-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 10px;
    border-radius: 4px;
    margin-bottom: 10px;
  }

  .s8-adv-6l .s8-adv-label {
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.12);
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .s8-adv-8l .s8-adv-label {
    color: var(--pcb-glow);
    background: rgba(0, 255, 65, 0.1);
    border: 1px solid rgba(0, 255, 65, 0.25);
  }

  /* Decision dashboard */
  .s8-adv-decision {
    margin-top: 40px;
    border: 1px solid var(--pcb-trace);
    border-radius: 8px;
    padding: 30px;
    background: rgba(5, 20, 10, 0.68);
  }

  .s8-adv-decision h3 {
    color: #fff;
    font-size: 1.3rem;
    margin: 0 0 16px;
  }

  .s8-adv-checklist {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .s8-check {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    color: var(--text-main);
    line-height: 1.4;
    font-size: 0.95rem;
  }

  .s8-check-icon {
    flex-shrink: 0;
    color: var(--pcb-glow);
    font-size: 1rem;
    margin-top: 2px;
  }

  .s8-check-note {
    margin-top: 18px;
    color: var(--pcb-glow);
    font-weight: 700;
    font-size: 1.05rem;
  }


  /* ================================================================
     SECTION 3 — STACKUP CONFIGURATIONS
     ================================================================ */
  .s8-stackup {
    background: rgba(5, 20, 10, 0.5);
  }

  .s8-stackup-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
  }

  .s8-stackup-card {
    border: 1px solid var(--pcb-trace);
    border-radius: 8px;
    overflow: hidden;
    background: rgba(5, 20, 10, 0.7);
  }

  .s8-stackup-card-alt {
    border-color: rgba(0, 255, 65, 0.25);
  }

  .s8-stackup-header {
    padding: 20px 24px;
    border-bottom: 1px solid rgba(0, 255, 65, 0.1);
    background: rgba(26, 66, 37, 0.35);
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .s8-stackup-num {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pcb-glow);
    background: rgba(0, 255, 65, 0.1);
    padding: 3px 10px;
    border-radius: 4px;
    border: 1px solid rgba(0, 255, 65, 0.2);
  }

  .s8-stackup-header h3 {
    color: #fff;
    font-size: 1.2rem;
    margin: 0;
  }

  .s8-stackup-tag {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 3px 10px;
    border-radius: 999px;
    margin-left: auto;
  }

  .s8-stackup-tag-green {
    background: rgba(0, 255, 65, 0.12);
    color: var(--pcb-glow);
    border: 1px solid rgba(0, 255, 65, 0.3);
  }

  .s8-stackup-tag-blue {
    background: rgba(59, 130, 246, 0.12);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .s8-stackup-tag-amber {
    background: rgba(245, 158, 11, 0.12);
    color: #fbbf24;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .s8-stackup-assignment {
    padding: 16px 24px;
    background: rgba(0, 0, 0, 0.2);
    border-bottom: 1px solid rgba(0, 255, 65, 0.08);
  }

  .s8-stackup-layer {
    padding: 6px 10px;
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.3;
    border-left: 3px solid transparent;
    margin-bottom: 1px;
  }

  .s8-layer-signal {
    color: #93c5fd;
    background: rgba(59, 130, 246, 0.08);
    border-left-color: #3b82f6;
  }

  .s8-layer-plane {
    color: var(--pcb-glow);
    background: rgba(0, 255, 65, 0.06);
    border-left-color: var(--pcb-glow);
  }

  .s8-layer-dielectric {
    color: #9ca3af;
    background: rgba(255, 255, 255, 0.02);
    border-left-color: #6b7280;
    font-weight: 400;
    font-size: 0.75rem;
    font-style: italic;
  }

  .s8-stackup-body {
    padding: 20px 24px 24px;
  }

  .s8-stackup-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
    padding: 12px 16px;
    background: rgba(0, 0, 0, 0.25);
    border-radius: 6px;
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-main);
  }

  .s8-stackup-metrics strong {
    color: #fff;
  }

  .s8-stackup-body p {
    color: var(--text-main);
    line-height: 1.7;
    font-size: 0.95rem;
    margin: 0 0 14px;
  }

  .s8-stackup-note {
    border-left: 3px solid var(--pcb-glow);
    padding: 12px 16px;
    background: rgba(0, 255, 65, 0.04);
    border-radius: 0 6px 6px 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-main);
    margin-top: 12px;
  }

  .s8-stackup-note strong {
    color: #fff;
  }


  /* ================================================================
     SECTION 4 — BACKDRILLING
     ================================================================ */
  .s8-backdrill {
    background: linear-gradient(180deg, rgba(0, 255, 65, 0.03), transparent);
    border-top: 1px solid rgba(0, 255, 65, 0.08);
    border-bottom: 1px solid rgba(0, 255, 65, 0.08);
  }

  .s8-backdrill-layout {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .s8-backdrill-primer h3,
  .s8-backdrill-frequency h3,
  .s8-backdrill-process h3,
  .s8-backdrill-guidance h3 {
    color: #fff;
    font-size: 1.3rem;
    margin: 0 0 16px;
  }

  .s8-backdrill-primer p,
  .s8-backdrill-process p {
    color: var(--text-main);
    line-height: 1.7;
    margin-bottom: 14px;
  }

  .s8-backdrill-primer ul {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
  }

  .s8-backdrill-primer ul li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 8px;
    color: var(--text-main);
    line-height: 1.5;
  }

  .s8-backdrill-primer ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pcb-glow);
    box-shadow: 0 0 6px rgba(0, 255, 65, 0.4);
  }

  /* Resonance calculator */
  .s8-backdrill-calc {
    border: 1px solid var(--pcb-trace);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 28px;
  }

  .s8-calc-row {
    display: grid;
    grid-template-columns: 1fr auto 1.8fr;
    gap: 12px;
    align-items: center;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(0, 255, 65, 0.08);
    font-size: 0.9rem;
    color: var(--text-main);
  }

  .s8-calc-row:last-child {
    border-bottom: none;
  }

  .s8-calc-row strong {
    color: var(--pcb-glow);
  }

  .s8-calc-arrow {
    color: rgba(0, 255, 65, 0.5);
    font-size: 1.1rem;
  }

  .s8-calc-row-result {
    background: rgba(0, 255, 65, 0.08);
    font-weight: 700;
  }

  .s8-calc-row-result strong {
    color: #fff;
  }

  /* Process steps */
  .s8-process-steps {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 28px;
  }

  .s8-bd-step {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 14px;
  }

  .s8-bd-num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0, 255, 65, 0.1);
    border: 1px solid var(--pcb-glow);
    color: var(--pcb-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .s8-bd-step h4 {
    color: #fff;
    font-size: 1rem;
    margin: 0 0 4px;
  }

  .s8-bd-step p {
    color: var(--text-main);
    line-height: 1.6;
    font-size: 0.92rem;
    margin: 0;
  }

  /* Guidance table */
  .s8-guidance-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
  }

  .s8-guidance-table th,
  .s8-guidance-table td {
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid rgba(0, 255, 65, 0.12);
    font-size: 0.88rem;
    color: var(--text-main);
  }

  .s8-guidance-table th {
    color: #fff;
    background: rgba(26, 66, 37, 0.5);
    font-weight: 700;
  }

  .s8-guidance-table td:last-child {
    color: var(--pcb-glow);
    font-weight: 600;
  }

  .s8-guidance-table tbody tr:last-child td {
    border-bottom: none;
  }

  .s8-backdrill-note {
    border: 1px solid var(--pcb-trace);
    border-radius: 8px;
    padding: 20px;
    background: rgba(0, 0, 0, 0.2);
  }

  .s8-backdrill-note h4 {
    color: #fff;
    font-size: 1.05rem;
    margin: 0 0 10px;
  }

  .s8-backdrill-note p {
    color: var(--text-main);
    line-height: 1.7;
    font-size: 0.93rem;
    margin: 0;
  }

  /* Backdrill sidebar */
  .s8-backdrill-sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .s8-sidebar-card {
    border: 1px solid var(--pcb-trace);
    border-radius: 8px;
    padding: 20px;
    background: rgba(5, 20, 10, 0.7);
  }

  .s8-sidebar-card h4 {
    color: #fff;
    font-size: 1.1rem;
    margin: 0 0 12px;
  }

  .s8-sidebar-card p {
    color: var(--text-main);
    line-height: 1.65;
    font-size: 0.92rem;
    margin: 0 0 10px;
  }

  .s8-sidebar-card p:last-child {
    margin-bottom: 0;
  }

  .s8-sidebar-card-dark {
    background: rgba(0, 0, 0, 0.3);
    border-color: rgba(0, 255, 65, 0.15);
  }

  .s8-sidebar-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .s8-sidebar-card ul li {
    position: relative;
    padding-left: 16px;
    margin-bottom: 8px;
    color: var(--text-main);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .s8-sidebar-card ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--pcb-glow);
  }

  .s8-sidebar-card ul li:last-child {
    margin-bottom: 0;
  }


  /* ================================================================
     SECTION 5 — SI WORKSHOP
     ================================================================ */
  .s8-si-workshop {
    background: rgba(5, 20, 10, 0.4);
  }

  .s8-si-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .s8-si-card {
    border: 1px solid var(--pcb-trace);
    border-radius: 8px;
    padding: 24px;
    background: rgba(5, 20, 10, 0.65);
  }

  .s8-si-card-wide {
    grid-column: 1 / -1;
  }

  .s8-si-card h3 {
    color: #fff;
    font-size: 1.15rem;
    margin: 0 0 14px;
  }

  .s8-si-card p {
    color: var(--text-main);
    line-height: 1.65;
    font-size: 0.93rem;
    margin: 0 0 14px;
  }

  .s8-si-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 12px;
  }

  .s8-si-table th,
  .s8-si-table td {
    padding: 8px 12px;
    text-align: left;
    border-bottom: 1px solid rgba(0, 255, 65, 0.1);
    font-size: 0.85rem;
    color: var(--text-main);
  }

  .s8-si-table th {
    color: #fff;
    background: rgba(26, 66, 37, 0.4);
    font-weight: 700;
    font-size: 0.8rem;
  }

  .s8-si-table tbody tr:last-child td {
    border-bottom: none;
  }

  .s8-si-note {
    font-size: 0.85rem !important;
    color: #9ca3af !important;
    margin-top: 8px !important;
  }

  /* Loss budget */
  .s8-loss-budget {
    border: 1px solid rgba(0, 255, 65, 0.12);
    border-radius: 6px;
    overflow: hidden;
  }

  .s8-loss-item {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1.5fr;
    gap: 12px;
    padding: 10px 14px;
    border-bottom: 1px solid rgba(0, 255, 65, 0.06);
    font-size: 0.85rem;
    align-items: center;
  }

  .s8-loss-item:last-child {
    border-bottom: none;
  }

  .s8-loss-label {
    color: var(--text-main);
  }

  .s8-loss-formula {
    color: #9ca3af;
    font-size: 0.8rem;
  }

  .s8-loss-example {
    color: var(--pcb-glow);
    font-weight: 600;
  }

  .s8-loss-item-total {
    background: rgba(0, 0, 0, 0.2);
    border-top: 1px solid rgba(0, 255, 65, 0.15);
  }

  .s8-loss-item-total .s8-loss-label {
    color: #fff;
    font-weight: 700;
  }

  .s8-loss-item-good {
    background: rgba(0, 255, 65, 0.06);
  }


  /* ================================================================
     SECTION 6 — HDI INTEGRATION
     ================================================================ */
  .s8-hdi {
    background: linear-gradient(180deg, transparent, rgba(0, 255, 65, 0.04));
  }

  .s8-hdi-layout {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .s8-hdi-block {
    margin-bottom: 28px;
  }

  .s8-hdi-block:last-child {
    margin-bottom: 0;
  }

  .s8-hdi-block h3 {
    color: #fff;
    font-size: 1.15rem;
    margin: 0 0 14px;
  }

  .s8-hdi-block p {
    color: var(--text-main);
    line-height: 1.7;
    font-size: 0.93rem;
    margin: 0 0 14px;
  }

  .s8-hdi-configs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .s8-hdi-config {
    border: 1px solid var(--pcb-trace);
    border-radius: 6px;
    padding: 14px;
    background: rgba(0, 0, 0, 0.15);
  }

  .s8-hdi-config-label {
    display: block;
    font-weight: 800;
    color: var(--pcb-glow);
    font-size: 0.82rem;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .s8-hdi-config p {
    font-size: 0.85rem;
    line-height: 1.55;
    margin: 0;
  }

  .s8-hdi-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 12px;
  }

  .s8-hdi-table th,
  .s8-hdi-table td {
    padding: 9px 12px;
    text-align: left;
    border-bottom: 1px solid rgba(0, 255, 65, 0.1);
    font-size: 0.84rem;
    color: var(--text-main);
  }

  .s8-hdi-table th {
    color: #fff;
    background: rgba(26, 66, 37, 0.4);
    font-weight: 700;
    font-size: 0.78rem;
  }

  .s8-hdi-table tbody tr:last-child td {
    border-bottom: none;
  }

  .s8-hdi-note {
    font-size: 0.85rem;
    color: #9ca3af;
    margin-top: 6px;
  }

  .s8-hdi-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .s8-hdi-list li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 10px;
    color: var(--text-main);
    line-height: 1.6;
    font-size: 0.92rem;
  }

  .s8-hdi-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pcb-glow);
  }

  .s8-hdi-list li strong {
    color: #fff;
  }

  /* HDI sidebar */
  .s8-hdi-sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .s8-flowchart {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .s8-flow-item {
    padding: 12px 14px;
    border-left: 2px solid var(--pcb-trace);
    font-size: 0.88rem;
    color: var(--text-main);
    position: relative;
  }

  .s8-flow-item:first-child {
    border-radius: 6px 6px 0 0;
  }

  .s8-flow-item:last-child {
    border-radius: 0 0 6px 6px;
    border-left-color: var(--pcb-glow);
  }

  .s8-flow-arrow {
    display: block;
    color: var(--pcb-glow);
    font-size: 0.8rem;
    margin: 4px 0;
  }

  .s8-flow-result {
    display: block;
    color: var(--pcb-glow);
    font-weight: 600;
    font-size: 0.84rem;
  }


  /* ================================================================
     SECTION 7 — HYBRID MATERIALS
     ================================================================ */
  .s8-hybrid {
    background: rgba(5, 20, 10, 0.4);
    border-top: 1px solid rgba(0, 255, 65, 0.06);
  }

  .s8-hybrid-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 28px;
    margin-bottom: 32px;
  }

  .s8-hybrid-text h3 {
    color: #fff;
    font-size: 1.15rem;
    margin: 0 0 14px;
  }

  .s8-hybrid-text p {
    color: var(--text-main);
    line-height: 1.7;
    font-size: 0.93rem;
    margin: 0 0 14px;
  }

  .s8-hybrid-text ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .s8-hybrid-text ul li {
    position: relative;
    padding-left: 18px;
    margin-bottom: 10px;
    color: var(--text-main);
    line-height: 1.6;
    font-size: 0.92rem;
  }

  .s8-hybrid-text ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--pcb-glow);
  }

  .s8-hybrid-text ul li strong {
    color: #fff;
  }

  /* Material compatibility table */
  .s8-hybrid-compat h3 {
    color: #fff;
    font-size: 1.05rem;
    margin: 0 0 14px;
  }

  .s8-hybrid-table {
    width: 100%;
    border-collapse: collapse;
  }

  .s8-hybrid-table th,
  .s8-hybrid-table td {
    padding: 8px 10px;
    text-align: left;
    border-bottom: 1px solid rgba(0, 255, 65, 0.08);
    font-size: 0.8rem;
    color: var(--text-main);
  }

  .s8-hybrid-table th {
    color: #fff;
    background: rgba(26, 66, 37, 0.4);
    font-weight: 700;
    font-size: 0.75rem;
  }

  .s8-hybrid-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* Hybrid stackup diagram */
  .s8-hybrid-stackup-example h3 {
    color: #fff;
    font-size: 1.1rem;
    margin: 0 0 16px;
  }

  .s8-hybrid-diagram {
    border: 1px solid var(--pcb-trace);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .s8-hybrid-layer {
    padding: 5px 12px;
    font-size: 0.75rem;
    line-height: 1.3;
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
  }

  .s8-hybrid-layer:last-child {
    border-bottom: none;
